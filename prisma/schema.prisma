generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
  skills   Skill[]
  journal  Journal[]
  // fcmTokens FcmToken[]
  notes    Note[]
}

// model FcmToken {
//   id        String   @id @default(cuid())
//   userId    String
//   token     String   @unique
//   createdAt DateTime @default(now())
//   user      User     @relation(fields: [userId], references: [id])
// }

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model Skill {
  id        String   @id @default(uuid())
  skillName String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([skillName, userId])
}

model Journal {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime
  journalContent String // what the user writes about the day
  createdAt      DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  tasks Task[]

  @@unique([userId, date]) // one journal per day per user
}

model Task {
  id        String   @id @default(uuid())
  journalId String
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  journal Journal @relation(fields: [journalId], references: [id])
}

model Note {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String?
  contentHTML String?
  contentJSON String?
  category    String?
  isStarred   Boolean  @default(false)
  isListNote  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isPublic    Boolean  @default(false)
  password    String?
  bookView    Boolean  @default(false)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  listItems NoteItem[]
}

model NoteItem {
  id        String   @id @default(cuid())
  noteId    String
  content   String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}
